{
  "ts-node": {
    "files": true
  },
  "compilerOptions": {

    "target": "es2017",                                  
    "lib": ["dom", "dom.iterable", "esnext"],                                    
    
    // Module imports (requires type: module in package.json)
    "module": "nodenext",
    "moduleResolution": "nodenext",     
    
    // Useful for debugging
    "sourceMap": true,
    
    "rootDir": "src",  
    "outDir": "./dist",                                  
    //"resolveJsonModule": true,                        
    "removeComments": true,   
    "esModuleInterop": true,                             
    "forceConsistentCasingInFileNames": true,            
    "strict": true,                                      
    "noImplicitAny": true,                            
    "skipLibCheck": true,
    "types": ["node"],                                 
  },
  "include": ["src/**/*"]
}
